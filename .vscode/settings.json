{
    "cmake.useCMakePresets": "always",
    "cmake.configureOnOpen": true,
    "C_Cpp.default.compilerPath": "arm-none-eabi-gcc",
    "C_Cpp.default.defines": [
        "__SAMD51P20A__"
    ],
    "C_Cpp.default.includePath": [
        "${workspaceFolder}/firmware/samd51/blinky/include",
        "${workspaceFolder}/firmware/samd51/common/include",
        "${workspaceFolder}/boards/board_common",
        "${workspaceFolder}/third_party/CMSIS_5/CMSIS/Core/Include",
        "${workspaceFolder}/third_party/samd51_dfp/samd51a/include"
    ],
    "files.associations": {
        "*.h": "c",
        "*.c": "c"
    }
}
