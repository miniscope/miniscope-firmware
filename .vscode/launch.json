{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug blinky_board (OpenOCD + Atmel-ICE)",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "openocd",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/blinky_board-debug/fw_blinky_board.elf",
            "device": "ATSAMD51P20A",
            "configFiles": [
                "interface/cmsis-dap.cfg",
                "target/atsame5x.cfg"
            ],
            "runToEntryPoint": "main",
            "svdFile": "${workspaceFolder}/third_party/samd51_dfp/samd51a/svd/ATSAMD51P20A.svd",
            "showDevDebugOutput": "none"
        }
    ]
}
