#ifndef FW_VERSION_H
#define FW_VERSION_H

/**
 * Firmware version information.
 *
 * Generated from git tags at configure time by cmake/version.cmake.
 * Do not edit this file directly — edit fw_version.h.in instead.
 */

#include <stdint.h>

#define FW_VERSION_MAJOR  @FW_VERSION_MAJOR@
#define FW_VERSION_MINOR  @FW_VERSION_MINOR@
#define FW_VERSION_PATCH  @FW_VERSION_PATCH@
#define FW_VERSION_STRING "@FW_VERSION_STRING@"
#define FW_VERSION_GIT_HASH "@FW_VERSION_GIT_HASH@"

typedef struct {
    uint8_t major;
    uint8_t minor;
    uint8_t patch;
    const char *version_string;
    const char *git_hash;
} fw_version_t;

/** Return a pointer to the firmware version info (static storage). */
const fw_version_t *fw_get_version(void);

#endif /* FW_VERSION_H */
