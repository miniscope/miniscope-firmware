#ifndef FW_CONFIG_H
#define FW_CONFIG_H

/**
 * Board-specific firmware configuration.
 *
 * Generated by CMake from fw_config.h.in using values from
 * board_config.cmake. Do not edit this file directly.
 */

/* Board identity */
#define FW_BOARD_NAME   "@BOARD_NAME@"
#define FW_BOARD_MCU    "@BOARD_MCU@"

/* CPU frequency */
#cmakedefine F_CPU @F_CPU@

/* Clock preset */
#cmakedefine HAL_CLOCK_PRESET @HAL_CLOCK_PRESET@

/* Feature flags — defined only when enabled in board_config.cmake */
#cmakedefine FW_ENABLE_UART
#cmakedefine FW_ENABLE_SPI
#cmakedefine FW_ENABLE_I2C
#cmakedefine FW_ENABLE_USB
#cmakedefine FW_ENABLE_DMA

#endif /* FW_CONFIG_H */
